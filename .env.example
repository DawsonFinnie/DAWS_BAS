# DAWS_BAS Environment Configuration
# Copy this file to .env and edit for your environment

# --- Network ---
RABBITMQ_IP=192.168.30.13
INFLUXDB_IP=192.168.30.14
GRAFANA_IP=192.168.30.16
NEO4J_IP=192.168.30.17
GATEWAY_IP=192.168.30.18

# --- RabbitMQ ---
RABBITMQ_USER=daws
RABBITMQ_PASS=changeme
RABBITMQ_VHOST=bas
RABBITMQ_EXCHANGE=daws.bas

# --- InfluxDB ---
INFLUXDB_ORG=DAWS
INFLUXDB_BUCKET=bas
INFLUXDB_TOKEN=changeme

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASS=changeme

# --- Neo4j ---
NEO4J_USER=neo4j
NEO4J_PASS=changeme

# --- Protocol Gateway ---
BACNET_NETWORK=192.168.30.0/24
BACNET_DEVICE_ID=9001
GATEWAY_POLL_INTERVAL=30

# --- General ---
TZ=America/Edmonton
